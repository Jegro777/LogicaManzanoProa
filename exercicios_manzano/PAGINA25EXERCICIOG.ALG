Algoritmo "Pagina25"
// Disciplina : Lï¿½gica de Programaï¿½ï¿½o
// Professor  : Jailson Costa dos Santos
// Descriï¿½ï¿½o  : Seis operaï¿½ï¿½es
// Autor(a)   : Thiago Jesus Dias 
// Data atual : 05/04/2026
Var

 a, b, c, d, resultado : inteiro
Inicio

 escreval("Valor a ser armazenado em A: ")
   leia(a)

   escreval("Valor a ser armazenado em B: ")
   leia(b)

   escreval("Valor a ser armazenado em C: ")
   leia(c)

   escreval("Valor a ser armazenado em D: ")
   leia(d)

   resultado <- A + B
   escreval("Valor de A+B: ", resultado)

   resultado <- A * B
   escreval("Valor de AxB: ", resultado)

   resultado <- A + C
   escreval("Valor de A+C: ", resultado)

   resultado <- A * C
   escreval("Valor de AxC: ", resultado)

   resultado <- A + D
   escreval("Valor de A+D: ", resultado)

   resultado <- A * D
   escreval("Valor de AxD: ", resultado)

   resultado <- B + C
   escreval("Valor de B+C: ", resultado)

   resultado <- B * C
   escreval("Valor de BxC: ", resultado)

   resultado <- B + D
   escreval("Valor de B+D: ", resultado)

   resultado <- B * C
   escreval("Valor de B*D: ", resultado)

   resultado <- C + D
   escreval("Valor de C+D: ", resultado)

   resultado <- C * D
   escreval("Valor de CxD: ", resultado)
Fimalgoritmo